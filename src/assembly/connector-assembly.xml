<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2
          http://maven.apache.org/xsd/assembly-1.1.2.xsd">

    <id>impl</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <fileSets>
        <!-- Include .impl file and classpath descriptor -->
        <fileSet>
            <outputDirectory/>
            <directory>target/classes</directory>
            <includes>
                <include>bwh-rest-execution.impl</include>
                <include>classpath</include>
            </includes>
        </fileSet>
        <!-- Include the connector JAR itself -->
        <fileSet>
            <outputDirectory>classpath</outputDirectory>
            <directory>${basedir}/target</directory>
            <includes>
                <include>${project.artifactId}-${project.version}.jar</include>
            </includes>
        </fileSet>
    </fileSets>

    <!-- Include runtime dependencies (shared library, etc.) -->
    <dependencySets>
        <dependencySet>
            <unpack>false</unpack>
            <scope>runtime</scope>
            <outputDirectory>classpath</outputDirectory>
        </dependencySet>
    </dependencySets>

</assembly>
