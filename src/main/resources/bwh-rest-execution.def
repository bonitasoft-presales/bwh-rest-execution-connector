<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1">

    <id>bwh-rest-execution</id>
    <version>1.0.0</version>
    <icon>connector.png</icon>

    <category icon="connector.png" id="ProcessBuilder"/>

    <!-- ================================================================== -->
    <!-- Inputs: Only configJson is required. Everything is resolved from    -->
    <!-- PBConfiguration (auth, methods, headers, etc.) via the configJson  -->
    <!-- Groovy script in PE_RestAPIConnector.                              -->
    <!-- ================================================================== -->
    <input mandatory="false" name="configJson"  type="java.lang.String"/>
    <input mandatory="false" name="verifySsl"   type="java.lang.Boolean" defaultValue="true"/>

    <!-- ================================================================== -->
    <!-- Outputs                                                            -->
    <!-- ================================================================== -->
    <output name="success"         type="java.lang.Boolean"/>
    <output name="errorMessage"    type="java.lang.String"/>
    <output name="statusCode"      type="java.lang.Integer"/>
    <output name="responseBody"    type="java.lang.String"/>
    <output name="responseHeaders" type="java.lang.String"/>
    <output name="executionTimeMs" type="java.lang.Long"/>
    <output name="requestUrl"      type="java.lang.String"/>

    <!-- ================================================================== -->
    <!-- Single page: Configuration JSON + SSL option                       -->
    <!-- ================================================================== -->
    <page id="configPage">
        <widget xsi:type="definition:Group" id="configGroup" optional="false">
            <widget xsi:type="definition:TextArea" id="configJsonWidget" inputName="configJson"/>
        </widget>
        <widget xsi:type="definition:Group" id="optionsGroup" optional="true">
            <widget xsi:type="definition:Checkbox" id="verifySslWidget" inputName="verifySsl"/>
        </widget>
    </page>

</definition:ConnectorDefinition>
